# Campaign Shorts Autopilot — configuration
# On a VM this file lives at /etc/autopilot.env (systemd EnvironmentFile).
# Only ANTHROPIC_API_KEY is strictly required; every platform is optional and
# switches on automatically when its keys are present.

# ─── Brain (required) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
#ANTHROPIC_MODEL=claude-sonnet-5        # default; claude-haiku-4-5-20251001 = cheaper

# ─── Your niche (drives research + scripts) ─────────────────────────────────
NICHE=e.g. AI side hustles for creators
AUDIENCE=e.g. 18-30yo creators who want online income
OFFER=e.g. Join my Whop community: https://whop.com/your-community
#TONE=energetic, direct, no fluff

# ─── Research sources (all keyless, all optional) ───────────────────────────
#TRENDS_GEO=US                          # Google Trends region
#RESEARCH_SUBREDDITS=Entrepreneur,SideProject
#RESEARCH_HN=1                          # include Hacker News front page

# ─── Cadence + housekeeping ─────────────────────────────────────────────────
#POSTS_PER_DAY=3                        # one short every 8h
#KEEP_VIDEOS=50                         # newest N videos kept on disk
#AUTOPILOT_DATA=/var/lib/autopilot      # journal, tokens, rendered videos
#AUTOPILOT_PORT=3444                    # /status + /media server
#AUTOPILOT_PUBLIC_BASE=http://YOUR_VM_IP:3444   # REQUIRED for Instagram (public video URL)

# ─── Rendering ──────────────────────────────────────────────────────────────
#PIPER_BIN=/usr/local/bin/piper         # natural TTS voice (recommended)
#PIPER_VOICE=/opt/piper/en_US-lessac-medium.onnx
#ESPEAK_VOICE=en-us+m3                  # fallback engine voice
#ESPEAK_WPM=165
#MUSIC_VOLUME=0.12                      # for assets/music/* bed
#CAPTION_FONT=DejaVu Sans

# ─── YouTube Shorts (native) ────────────────────────────────────────────────
# Google Cloud → enable "YouTube Data API v3" → OAuth client, type
# "TV and Limited Input devices". Then once: node autopilot.js auth-youtube
YT_CLIENT_ID=
YT_CLIENT_SECRET=
#YT_PRIVACY=public                      # public | unlisted | private

# ─── Instagram Reels (native) ───────────────────────────────────────────────
# Professional IG account linked to a FB Page; Meta app with
# instagram_content_publish. Needs AUTOPILOT_PUBLIC_BASE set (see above).
IG_USER_ID=
IG_ACCESS_TOKEN=

# ─── TikTok (native) ────────────────────────────────────────────────────────
# developers.tiktok.com app with the Content Posting API (video.publish).
# Note: unaudited apps can only post SELF_ONLY (private) — flip TIKTOK_PRIVACY
# to PUBLIC_TO_EVERYONE once your app passes TikTok's audit.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
#TIKTOK_PRIVACY=SELF_ONLY

# ─── Webhook fan-out (fastest path — no platform apps needed) ───────────────
# Zapier/Make/n8n/Buffer catch-hook; receives JSON with video_url + copy and
# your zap posts it anywhere. Pair with AUTOPILOT_PUBLIC_BASE for the file.
WEBHOOK_URL=

# ─── Whop (posted last, links to the socials above) ─────────────────────────
# whop.com dashboard → Developer → API key. Experience id of your forum
# ("exp_…"), or literally "public" plus your company id ("biz_…").
WHOP_API_KEY=
WHOP_EXPERIENCE_ID=
#WHOP_COMPANY_ID=
