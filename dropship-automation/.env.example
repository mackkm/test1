# Copy this file to .env and fill in real values. Never commit .env.

# --- Shopify ---
# Your store's *.myshopify.com domain
SHOPIFY_SHOP=pawlettes.myshopify.com
# Admin API access token from your custom app (Settings > Apps and sales channels >
# Develop apps > [your app] > API credentials). Needs scopes:
# read_products, write_products, read_orders, write_orders
SHOPIFY_ADMIN_API_ACCESS_TOKEN=
# API secret key from the same custom app page - used to verify webhook HMACs
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2024-10

# Public URL this server is reachable at once deployed, e.g. https://pawlette-automation.example.com
# Required for `npm run register-webhooks`.
PUBLIC_BASE_URL=

# --- Printful ---
# Printful dashboard > Stores > [your store] > API
PRINTFUL_API_KEY=
# Optional: set after configuring a Printful webhook for package_shipped events
PRINTFUL_WEBHOOK_SECRET=

# --- Pricing ---
# Retail price = supplier cost price * MARKUP_MULTIPLIER
MARKUP_MULTIPLIER=2.5

# --- Server ---
PORT=3000
DATA_DIR=./data
INVENTORY_SYNC_INTERVAL_MINUTES=60
